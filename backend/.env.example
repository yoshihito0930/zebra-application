# JWT Secret (開発環境用)
# 本番環境では必ず環境変数で設定すること
JWT_SECRET=your-secret-key-here

# SES Configuration (ゲスト予約メール送信用)
SES_SENDER_EMAIL=noreply@studio-zebra.com
SES_REGION=ap-northeast-1

# メール送信のドライラン (true の場合、実際にSESへ送信せずログ出力のみ。誤送信防止)
# dev環境では true、本番では false（実送信）を推奨
EMAIL_DRY_RUN=false

# ゲスト予約確認ページのベースURL
GUEST_RESERVATION_URL=https://studio-zebra.com/reservations/guest

# Log Level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO
